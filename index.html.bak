<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vindhya Cheepulla | Software Trainee</title>

  <!-- Fonts & Icons -->
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <!-- Animation Libraries -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="https://unpkg.com/@studio-freight/lenis@1.0.33/dist/lenis.min.js"></script>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --gold-primary: #d4af37;
      --gold-light: #f9e596;
      --red-velvet: #4a0808;
      --bg-void: #0a0000;
      --text-main: #fdfbf7;
      --text-muted: #c4b5b5;
      --morning-mist: #ADA7B9;
      --rose-gold: #B76E79;
      --glass-bg: rgba(255, 255, 255, 0.05);
      --glass-border: rgba(255, 255, 255, 0.15);
    }

    body {
      font-family: 'Inter', sans-serif;
      background: radial-gradient(circle at 50% -20%, #4a0808, #0a0000 80%);
      color: var(--text-main);
      overflow-x: hidden;
    }

    /* Curtain */
    .curtain-wrapper {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      z-index: 9999;
      display: flex;
      pointer-events: none;
    }

    .curtain-panel {
      flex: 1;
      height: 100%;
      background: #0a0000;
      border-right: 1px solid rgba(212, 175, 55, 0.1);
    }

    .curtain-loader-text {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: 'Playfair Display', serif;
      font-size: 4rem;
      color: #d4af37;
      letter-spacing: 15px;
      z-index: 10000;
    }

    /* Navbar */
    .navbar {
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 2000;
      padding: 2rem;
    }

    .navbar.scrolled {
      background: rgba(10, 0, 0, 0.9);
      backdrop-filter: blur(10px);
    }

    .nav-container {
      max-width: 1400px;
      margin: auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 4%;
    }

    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      color: #f9e596;
    }

    .nav-links {
      display: flex;
      gap: 4rem;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      color: white;
      letter-spacing: 2px;
    }

    /* HERO SECTION - Your name and role appear FIRST after curtain */
    .hero-section {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 0 5%;
      position: relative;
    }

    .hero-name {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3rem, 8vw, 6rem);
      color: #f9e596;
      letter-spacing: 4px;
      margin-bottom: 1.5rem;
      opacity: 0;
      transform: translateY(30px);
    }

    .hero-role {
      font-size: clamp(1rem, 3vw, 1.5rem);
      color: #c4b5b5;
      letter-spacing: 2px;
      max-width: 800px;
      opacity: 0;
      transform: translateY(30px);
    }

    .scroll-indicator {
      position: absolute;
      bottom: 50px;
      opacity: 0;
    }

    /* Sections */
    section {
      padding: 100px 4%;
      max-width: 1400px;
      margin: auto;
    }

    h2 {
      font-family: 'Playfair Display', serif;
      font-size: 3rem;
      color: #f9e596;
      text-align: center;
      margin-bottom: 3rem;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 30px;
    }

    .card {
      background: rgba(30, 4, 4, 0.45);
      backdrop-filter: blur(10px);
      padding: 40px;
      border: 1px solid rgba(212, 175, 55, 0.25);
    }

    .card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      margin-bottom: 1rem;
      color: #f9e596;
    }

    .card p {
      color: #c4b5b5;
      margin-bottom: 1.5rem;
    }

    .project-link {
      color: #d4af37;
      text-decoration: none;
      display: inline-block;
      margin-right: 20px;
    }

    .skills-container {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 20px;
    }

    .skill-chip {
      padding: 5px 15px;
      background: rgba(0, 0, 0, 0.6);
      border: 1px solid rgba(212, 175, 55, 0.2);
      color: white;
      font-size: 0.9rem;
    }

    .contact-card {
      text-align: center;
      padding: 80px 40px;
      border-top: 1px solid #d4af37;
      border-bottom: 1px solid #d4af37;
    }

    .contact-email {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      color: #f9e596;
      text-decoration: none;
      display: block;
      margin-bottom: 2rem;
    }

    .social-links {
      display: flex;
      justify-content: center;
      gap: 30px;
    }

    .social-links a {
      color: #c4b5b5;
      font-size: 1.5rem;
    }

    /* Glassmorphism About Section */
    .about-section {
      position: relative;
      width: 100%;
      z-index: 1;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .glass-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: 24px;
      padding: 4rem 3rem;
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      text-align: center;
      transition: transform 0.3s ease;
      max-width: 900px;
      width: 100%;
    }

    .glass-card:hover {
      transform: translateY(-5px);
    }

    .glass-card .title {
      font-family: 'Playfair Display', serif;
      font-size: 3rem;
      color: var(--rose-gold);
      margin-bottom: 2rem;
      letter-spacing: 1px;
    }

    .glass-card .description {
      font-size: 1.2rem;
      line-height: 1.8;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 2.5rem;
    }

    .glass-card .highlight {
      color: var(--rose-gold);
      font-weight: 600;
    }

    .skills-pills {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .pill {
      background: rgba(183, 110, 121, 0.15);
      border: 1px solid var(--rose-gold);
      color: var(--rose-gold);
      padding: 0.5rem 1.2rem;
      border-radius: 50px;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    .orb {
      position: absolute;
      width: 300px;
      height: 300px;
      border-radius: 50%;
      filter: blur(80px);
      z-index: -1;
      opacity: 0.4;
    }

    .orb-1 {
      background: var(--rose-gold);
      top: -50px;
      right: 10%;
    }

    .orb-2 {
      background: var(--morning-mist);
      bottom: -50px;
      left: 10%;
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: #c4b5b5;
    }

    @media (max-width: 768px) {
      .nav-links {
        display: none;
      }
    }
  </style>
</head>

<body>
  <!-- Curtain -->
  <div class="curtain-loader-text" id="curtainText">VINDHYA</div>
  <div class="curtain-wrapper" id="curtainWrapper">
    <div class="curtain-panel"></div>
    <div class="curtain-panel"></div>
    <div class="curtain-panel"></div>
    <div class="curtain-panel"></div>
